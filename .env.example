# ── Finance DB (user accounts) ──────────────────────────────
DB_HOST=your-finance-db-host
DB_PORT=3306
DB_USER=your-finance-db-user
DB_PASSWORD=your-finance-db-password
DB_NAME=your-finance-db-name

# ── DriveU DB (bookings + logs) ──────────────────────────────
DRIVEU_DB_HOST=your-driveu-db-host
DRIVEU_DB_PORT=3306
DRIVEU_DB_USER=your-driveu-db-user
DRIVEU_DB_PASSWORD=your-driveu-db-password
DRIVEU_DB_NAME=your-driveu-db-name

# ── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_URL=https://your-subdomain.yourdomain.com
NEXTAUTH_SECRET=generate-with: openssl rand -base64 32

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Admin credentials ─────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-admin-password
